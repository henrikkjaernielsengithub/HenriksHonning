<svg class="draw" viewBox="0 0 220 250" role="img" aria-label="Studieblad: opstablingsstade med magasin, yngelrum og flyvespalte">
  <defs>
    <pattern id="ch-pl-stade" width="7" height="7" patternUnits="userSpaceOnUse" patternTransform="rotate(38)">
      <line x1="0" y1="0" x2="0" y2="7" stroke="#6b5334" stroke-width=".7" opacity=".4"/>
    </pattern>
    <filter id="rough-pl-stade"><feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" result="n"/><feDisplacementMap in="SourceGraphic" in2="n" scale="2"/></filter>
  </defs>
  <ellipse cx="110" cy="120" rx="96" ry="90" fill="#efe7d3" opacity=".6"/>
  <g filter="url(#rough-pl-stade)">
    <!-- tag -->
    <path class="sketch animate-draw" stroke-width="1.4" d="M52 46 h116 v12 h-116 Z" fill="url(#ch-pl-stade)"/>
    <!-- magasin -->
    <path class="sketch animate-draw" stroke-width="1.5" d="M60 62 h100 v34 h-100 Z"/>
    <path class="sketch" stroke-width=".9" d="M66 70 h20 M66 74 h20"/>
    <!-- yngelrum (dybere kasse) -->
    <path class="sketch animate-draw" stroke-width="1.5" d="M60 100 h100 v52 h-100 Z" fill="url(#ch-pl-stade)"/>
    <path class="sketch" stroke-width=".9" d="M134 108 h20 M134 112 h20"/>
    <!-- bund med flyvespalte og flyvebræt -->
    <path class="sketch" stroke-width="1.4" d="M56 156 h108 v12 h-108 Z"/>
    <path class="sketch" stroke-width="2.2" d="M78 168 h48"/>
    <path class="sketch animate-draw" stroke-width="1.2" d="M56 168 l-10 12 h118 l-10 -12"/>
    <!-- ben -->
    <path class="sketch" stroke-width="1.3" d="M66 180 v18 M154 180 v18"/>
    <!-- indflyvende bi -->
    <g class="sketch" stroke-width="1">
      <ellipse cx="34" cy="142" rx="6" ry="4.5" transform="rotate(24 34 142)"/>
      <path d="M31 141 l6 3 M30 144 l7 2" stroke-width=".8"/>
      <path class="sketch-faint" d="M42 148 C 54 158, 66 162, 80 166" stroke-width=".7" stroke-dasharray="2 5"/>
    </g>
    <!-- markeringer -->
    <text class="annot" x="166" y="83" font-size="13">magasin</text>
    <text class="annot" x="163" y="128" font-size="12.5">yngelrum</text>
    <path class="sketch-faint" stroke-width=".7" stroke-dasharray="1 5" d="M74 172 C 60 178, 50 186, 44 196"/>
    <text class="annot" x="14" y="212" font-size="13">flyvespalte</text>
    <text class="annot" x="110" y="238" font-size="17" text-anchor="middle" letter-spacing=".05em">opstablingsstade</text>
  </g>
</svg>
