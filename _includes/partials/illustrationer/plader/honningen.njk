<svg class="draw" viewBox="0 0 220 250" role="img" aria-label="Studieblad: honningtavle med forseglet og åben honning">
  <defs>
    <pattern id="ch-pl-honning" width="7" height="7" patternUnits="userSpaceOnUse" patternTransform="rotate(38)">
      <line x1="0" y1="0" x2="0" y2="7" stroke="#6b5334" stroke-width=".7" opacity=".4"/>
    </pattern>
    <pattern id="celler-pl" width="56" height="97" patternUnits="userSpaceOnUse" patternTransform="scale(.43)">
