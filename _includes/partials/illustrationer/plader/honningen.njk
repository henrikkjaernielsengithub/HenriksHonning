    <path class="sketch" stroke-width="1" d="M46 70 h128 v34 c-42 10, -86 10, -128 0 Z" fill="url(#ch-pl-honning)"/>
    <!-- markeringer -->
    <path class="sketch-faint" stroke-width=".7" stroke-dasharray="1 5" d="M148 52 C 142 60, 138 66, 136 76"/>
    <text class="annot" x="146" y="46" font-size="13">forseglet</text>
    <path class="sketch-faint" stroke-width=".7" stroke-dasharray="1 5" d="M62 150 C 48 156, 38 164, 32 174"/>
    <text class="annot" x="18" y="192" font-size="13">åben</text>
    <text class="annot" x="110" y="226" font-size="17" text-anchor="middle" letter-spacing=".05em">honningtavle</text>
  </g>
</svg>
