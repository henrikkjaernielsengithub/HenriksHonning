    <path class="sketch animate-draw" stroke-width="1.6" d="M38 62 h144 v118 h-144 Z"/>
    <path class="sketch" stroke-width="1.1" d="M30 54 h160 v8 h-160 Z" fill="url(#ch-pl-honning)"/>
    <path class="sketch" stroke-width="1" d="M46 70 h128 v102 h-128 Z"/>
    <!-- tavletråde -->
    <path class="sketch-faint" stroke-width=".7" d="M46 96 h128 M46 130 h128 M46 158 h128"/>
    <!-- cellevæg-tekstur -->
    <rect x="46" y="70" width="128" height="102" fill="url(#celler-pl)"/>
