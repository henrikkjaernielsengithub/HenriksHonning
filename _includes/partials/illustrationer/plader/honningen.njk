    <filter id="rough-pl-honning"><feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" result="n"/><feDisplacementMap in="SourceGraphic" in2="n" scale="2"/></filter>
  </defs>
  <ellipse cx="110" cy="118" rx="98" ry="86" fill="#efe7d3" opacity=".6"/>
