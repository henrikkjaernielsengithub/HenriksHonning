{# Henriks Honning — brand-logo som skarp SVG. To varianter: logoMark (kompakt bi-sekskant) og logoLockup (fuldt logo med tekst). #}

{% macro bee(idp) %}
  {# vinger #}
  <g fill="#e8be3f" opacity=".45">
    <ellipse cx="30" cy="39" rx="19" ry="9" transform="rotate(-30 30 39)"/>
    <ellipse cx="70" cy="39" rx="19" ry="9" transform="rotate(30 70 39)"/>
    <ellipse cx="35" cy="53" rx="12" ry="6.5" transform="rotate(-16 35 53)"/>
    <ellipse cx="65" cy="53" rx="12" ry="6.5" transform="rotate(16 65 53)"/>
  </g>
  {# følehorn #}
  <path d="M46 23 C 41 15 37 12 34 11 M54 23 C 59 15 63 12 66 11" fill="none" stroke="#e8be3f" stroke-width="2.4" stroke-linecap="round"/>
  {# hoved + bryst #}
  <circle cx="50" cy="24" r="6.5" fill="#e8be3f"/>
  <ellipse cx="50" cy="39" rx="10.5" ry="9.5" fill="#e8be3f"/>
  {# bagkrop med striber (klippet til dråbeform) #}
  <clipPath id="abd-{{ idp }}">
    <path d="M50 48 C 61 48 63 59 58.5 69 C 55.5 77 50 85 50 85 C 50 85 44.5 77 41.5 69 C 37 59 39 48 50 48 Z"/>
  </clipPath>
  <g clip-path="url(#abd-{{ idp }})">
    <rect x="36" y="48" width="28" height="38" fill="#e8be3f"/>
    <g fill="#16130c">
      <rect x="34" y="55" width="32" height="3.4"/>
      <rect x="34" y="63" width="32" height="3.4"/>
      <rect x="34" y="71" width="32" height="3.4"/>
    </g>
  </g>
{% endmacro %}

{% macro logoMark() %}
<svg class="brand-logo" width="36" height="39" viewBox="0 0 100 108" aria-hidden="true">
  <path d="M50 2 94 27v54L50 106 6 81V27Z" fill="#16130c"/>
  {{ bee('mark') }}
</svg>
{% endmacro %}

{% macro logoLockup() %}
<svg class="footer-logo" viewBox="0 0 200 236" role="img" aria-label="Henriks Honning, Hingeballe">
  <path d="M100 4 190 56v124L100 232 10 180V56Z" fill="#16130c"/>
  <svg x="60" y="24" width="80" height="80" viewBox="0 0 100 100">{{ bee('lockup') }}</svg>
  <text x="100" y="150" text-anchor="middle" fill="#f6f1e5" font-family="Inter,system-ui,sans-serif" font-weight="600" letter-spacing="5" font-size="21">HENRIKS</text>
  <text x="100" y="176" text-anchor="middle" fill="#f6f1e5" font-family="Inter,system-ui,sans-serif" font-weight="600" letter-spacing="5" font-size="21">HONNING</text>
  <text x="100" y="200" text-anchor="middle" fill="#d9b23a" font-family="Inter,system-ui,sans-serif" font-weight="600" letter-spacing="6" font-size="10">HINGEBALLE</text>
</svg>
{% endmacro %}
